NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# API-Football (optional — free plan only covers seasons 2022–2024, NOT 2026)
# Without a paid plan, matches are seeded from built-in data on login.
NEXT_PUBLIC_API_FOOTBALL_KEY=your-api-football-key
NEXT_PUBLIC_ENABLE_API_FOOTBALL_WIDGETS=false

# Server-only — used for match seeding on login
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
API_FOOTBALL_KEY=your-api-football-key
CRON_SECRET=generate-a-random-secret
